a[href]:hover   { background: rgb(240,240,243); }

.sidebar { 
   background: rgb(220,220,220);
/*   border: 2px outset; */
}

.menubar {  
   background: rgb(220,220,220);
/*   border: 2px outset; */
}

.sidemenu ul li.current > a { font-weight: bold; ; }

.sidemenu ul li.current > a:before { content: "[" ; }
.sidemenu ul li.current > a:after { content: "]" ; }

